{
  "version": 3,
  "configurePresets": [
    {
      "name": "rls",
      "generator": "Ninja",
      "binaryDir": "build-rls/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "dbg",
      "inherits": "rls",
      "binaryDir": "build-dbg/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dbg-nomtln",
      "inherits": "dbg",
      "binaryDir": "build-dbg-nomtln/",
      "cacheVariables": {
        "SEMBA_FDTD_ENABLE_MTLN": "OFF"
      }
    },
    {
      "name": "intel-rls",
      "generator": "Ninja",
      "binaryDir": "build-intel-rls/",
      "environment": {
        "I_MPI_ROOT": "/opt/intel/oneapi/mpi/latest",
        "FC": "mpiifx",
        "CC": "mpiicx",
        "CXX": "mpiicpx"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SEMBA_FDTD_ENABLE_MPI": "ON",
        "SEMBA_FDTD_ENABLE_MTLN": "ON",
        "SEMBA_FDTD_ENABLE_DOUBLE_PRECISION": "ON"
      }
    },
    {
      "name": "intel-dbg-nomtln",
      "inherits": "intel-rls",
      "binaryDir": "build-intel-dbg-nomtln/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SEMBA_FDTD_ENABLE_MTLN": "OFF"
        
      }
    }
  ]
}
